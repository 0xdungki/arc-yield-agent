# Arc Stablecoin Yield Agent config
# Never commit a real private key.

PRIVATE_KEY=0xYOUR_TESTNET_PRIVATE_KEY
RPC_URL=https://rpc.testnet.arc.network

# Current Arc testnet deployment
USDC_ADDRESS=0xfd483B685d9f291606b9f70511E13436c091274E
VAULTS=0xC2776af10e1721655747508941475C058Eb12556,0x36E5d19996df30A8c3E31c7Adaa069dDC522276D,0x2e02C3C3F00A10F0f1CF2E511a97F7670365002b

# Agent controls
# 0 = use all idle MockUSDC. Otherwise amount in MockUSDC units, e.g. 500.
REBALANCE_AMOUNT=0
# false = scan/recommend only, true = withdraw/deposit.
EXECUTE=false
